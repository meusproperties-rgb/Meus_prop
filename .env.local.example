# Copy this file to .env.local in the project root.

# Database (PostgreSQL)
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/meus_realestate"
# Hosted example:
# DATABASE_URL="postgresql://user:password@host:5432/realestate?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/meus_realestate"

# Optional DB SSL override:
# true / require -> force SSL
# false / disable -> disable SSL
# Leave unset to auto-detect based on localhost vs hosted
DB_SSL="false"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# AUTH_SECRET can also be used instead of NEXTAUTH_SECRET.

# Optional Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Optional seeded admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Administrator"

# Temporary hardcoded admin login
ADMIN_LOGIN_EMAIL="admin@meus.ae"
ADMIN_LOGIN_PASSWORD="Admin@12345"
ADMIN_LOGIN_NAME="Admin User"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Meus Real Estate"
